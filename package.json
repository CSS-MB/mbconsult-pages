{
  "name": "mbconsult-pages",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "start": "python3 -m http.server 8000",
    "test": "cypress run",
    "test:open": "cypress open",
    "sass": "sass assets/sass/main.scss assets/css/main.css",
    "sass:watch": "sass --watch assets/sass/main.scss:assets/css/main.css",
    "validate": "htmlhint *.html",
    "dev": "live-server --port=8080 --host=localhost --no-browser"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^24.2.1",
    "cypress": "^14.5.4"
  }
}
